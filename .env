PORT=3000
NODE_ENV=development
LOG_LEVEL=info
BASE_URL=http://localhost:3000
REDIRECT_STATUS=301

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=urlshortener

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# API Keys
API_KEY_PREFIX=sk_live_

# CORS
CORS_ORIGIN=*

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=25000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=10
